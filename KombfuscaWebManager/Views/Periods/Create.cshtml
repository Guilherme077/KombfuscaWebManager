@model KombfuscaWebManager.Models.CupModels.Period

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Period</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="PaperNumber" class="control-label"></label>
                <input asp-for="PaperNumber" class="form-control" />
                <span asp-validation-for="PaperNumber" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CopaId" class="control-label"></label>
                <select asp-for="CopaId" class="form-control" asp-items="ViewBag.CopaId">
                    <option value="">-- Select a Cup --</option>
                </select>
                <span asp-validation-for="CopaId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
