@using KombfuscaWebManager.Models.CupModels.ViewModels
@model ScoreIndexViewModel

@{
    ViewData["Title"] = "Scores";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1>Envio de Pontuações</h1>
            <p class="text-muted">Selecione um período para enviar a planilha de pontuação</p>
        </div>
    </div>

    @if (!Model.CupGroups.Any())
    {
        <div class="alert alert-info" role="alert">
            <strong>Nenhuma competição disponível.</strong> Aguarde a criação de novas competições.
        </div>
    }
    else
    {
        @foreach (var cupGroup in Model.CupGroups)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-trophy"></i> @cupGroup.CupName
                    </h4>
                </div>

                <div class="card-body">
                    @if (cupGroup.PendingPeriods.Any())
                    {
                        <div class="mb-4">
                            <h5 class="text-danger">
                                <i class="fas fa-exclamation-circle"></i> 
                                Períodos Pendentes (@cupGroup.PendingPeriods.Count)
                            </h5>
                            <p class="text-muted small">Você ainda não enviou a pontuação destes períodos</p>

                            <div class="row">
                                @foreach (var period in cupGroup.PendingPeriods)
                                {
                                    <div class="col-md-6 col-lg-4 mb-3">
                                        <div class="card h-100 border-danger border-2">
                                            <div class="card-body d-flex flex-column">
                                                <h6 class="card-title text-danger font-weight-bold">
                                                    <i class="fas fa-file-alt"></i> Período @period.PaperNumber
                                                </h6>
                                                @if (!string.IsNullOrEmpty(period.Description))
                                                {
                                                    <p class="card-text text-muted small flex-grow-1">
                                                        @period.Description
                                                    </p>
                                                }
                                                <p class="card-text text-muted flex-grow-1">
                                                    Envie a planilha de pontuação
                                                </p>
                                                <div class="d-grid gap-2">
                                                    <a href="@Url.Action("RegisterScore", "Score", new { periodId = period.PeriodId })" 
                                                       class="btn btn-danger btn-sm">
                                                        <i class="fas fa-upload"></i> Enviar Pontuação
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        @if (cupGroup.CompletedPeriods.Any())
                        {
                            <hr />
                        }
                    }

                    @if (cupGroup.CompletedPeriods.Any())
                    {
                        <div>
                            <h5 class="text-success">
                                <i class="fas fa-check-circle"></i> 
                                Períodos Completados (@cupGroup.CompletedPeriods.Count)
                            </h5>
                            <p class="text-muted small">Você já enviou a pontuação destes períodos</p>

                            <div class="table-responsive">
                                <table class="table table-sm table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Período</th>
                                            <th>Descrição</th>
                                            <th>Data de Envio</th>
                                            <th>Ações</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var period in cupGroup.CompletedPeriods)
                                        {
                                            <tr class="text-muted">
                                                <td>
                                                    <i class="fas fa-check-circle text-success"></i> 
                                                    Período @period.PaperNumber
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(period.Description))
                                                    {
                                                        <small>@period.Description</small>
                                                    }
                                                </td>
                                                <td>
                                                    @if (period.ScoreCreatedAt.HasValue)
                                                    {
                                                        <small>@period.ScoreCreatedAt.Value.ToString("dd/MM/yyyy HH:mm")</small>
                                                    }
                                                </td>
                                                <td>
                                                    <a href="@Url.Action("RegisterScore", "Score", new { periodId = period.PeriodId })" 
                                                       class="btn btn-sm btn-outline-secondary"
                                                       title="Reenviar">
                                                        <i class="fas fa-redo"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}
