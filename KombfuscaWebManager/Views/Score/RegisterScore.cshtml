@{
}

<h2>Registrar a Pontuação no Sistema</h2>
<h2>Registro por Imagem da Folha de Pontuação</h2>

<form asp-action="UploadScoreSheet"
      asp-controller="Score"
      method="post"
      enctype="multipart/form-data">

    <input type="text"
           name="periodId"
           value="@ViewBag.PeriodId" />

    <div class="mb-3">
        <label class="form-label">
            Imagem da folha
        </label>

        <input type="file"
               class="form-control"
               name="image"
               accept=".jpg,.jpeg,.png"
               required />
    </div>

    <button type="submit" class="btn btn-primary">
        Registrar
    </button>

    <a asp-action="Index"
           class="btn btn-secondary">
        Cancelar
    </a>

</form>