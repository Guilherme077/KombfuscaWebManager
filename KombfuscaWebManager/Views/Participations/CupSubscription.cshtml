@using KombfuscaWebManager.Models.CupModels.ViewModels
@model CupSubscriptionViewModel

@{
    ViewData["Title"] = "Inscrição na Copa";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <h1 class="mb-4">
                <i class="fas fa-trophy"></i> Inscrição na Copa
            </h1>

            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-info-circle"></i> Informações da Copa
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h5 class="text-primary">@Model.CupName</h5>
                            <dl class="row">
                                <dt class="col-sm-4">Local:</dt>
                                <dd class="col-sm-8">@Model.Placename</dd>

                                <dt class="col-sm-4">Ano:</dt>
                                <dd class="col-sm-8">@Model.Year</dd>

                                <dt class="col-sm-4">Data Início:</dt>
                                <dd class="col-sm-8">@Model.StartDate.ToString("dd/MM/yyyy")</dd>

                                @if (Model.EndDate.HasValue)
                                {
                                    <dt class="col-sm-4">Data Fim:</dt>
                                    <dd class="col-sm-8">@Model.EndDate.Value.ToString("dd/MM/yyyy")</dd>
                                }

                                <dt class="col-sm-4">Taxa de Inscrição:</dt>
                                <dd class="col-sm-8">R$ @Model.SubscriptionFee.ToString("F2")</dd>

                                <dt class="col-sm-4">Status:</dt>
                                <dd class="col-sm-8">
                                    @{
                                        var statusBadge = Model.CupStatus switch
                                        {
                                            "openSubscriptions" => "badge-success",
                                            "closedSubscriptions" => "badge-warning",
                                            "running" => "badge-info",
                                            "finished" => "badge-secondary",
                                            "finishedResultsAvailable" => "badge-primary",
                                            _ => "badge-dark"
                                        };

                                        var statusLabel = Model.CupStatus switch
                                        {
                                            "openSubscriptions" => "Inscrições Abertas",
                                            "closedSubscriptions" => "Inscrições Fechadas",
                                            "running" => "Em Andamento",
                                            "finished" => "Finalizado",
                                            "finishedResultsAvailable" => "Resultados Disponíveis",
                                            _ => Model.CupStatus
                                        };
                                    }
                                    <span class="badge @statusBadge">@statusLabel</span>
                                </dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-edit"></i> Dados de Inscrição
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="CupSubscription" method="post">
                        <input type="hidden" asp-for="CupId" />

                        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                        <div class="form-group mb-3">
                            <label asp-for="TeamName" class="form-label">
                                <strong>Nome do seu Time</strong>
                            </label>
                            <input asp-for="TeamName" 
                                   class="form-control form-control-lg" 
                                   placeholder="Digite o nome do seu time"
                                   required />
                            <span asp-validation-for="TeamName" class="text-danger"></span>
                            <small class="form-text text-muted">
                                O nome do time será utilizado para identificar sua participação na copa
                            </small>
                        </div>

                        <div class="form-group">
                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                <a href="@Url.Action("Index", "Cups")" class="btn btn-secondary btn-lg">
                                    <i class="fas fa-times"></i> Cancelar
                                </a>
                                <button type="submit" class="btn btn-success btn-lg">
                                    <i class="fas fa-check"></i> Confirmar Inscrição
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}
