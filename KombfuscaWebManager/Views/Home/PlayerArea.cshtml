@{
    ViewData["Title"] = "Área do Competidor";
}

<style>
    .player-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 60px 0;
        margin-bottom: 40px;
        border-radius: 10px;
    }

    .player-hero h1 {
        font-size: 2.5rem;
        font-weight: bold;
        margin-bottom: 15px;
    }

    .player-hero p {
        font-size: 1.1rem;
        opacity: 0.9;
    }

    .action-card {
        border: none;
        border-radius: 12px;
        transition: all 0.3s ease;
        height: 100%;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

    .action-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    }

    .action-card .card-header {
        padding: 25px;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 120px;
    }

    .action-card .card-body {
        padding: 25px;
    }

    .action-card .card-footer {
        padding: 15px 25px;
        background-color: #f8f9fa;
        border-top: 1px solid #e9ecef;
    }

    .card-icon {
        font-size: 3rem;
        margin-bottom: 10px;
    }

    .badge-status {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        margin: 5px 0;
    }

    .badge-active {
        background-color: #d4edda;
        color: #155724;
    }

    .badge-completed {
        background-color: #cfe2ff;
        color: #084298;
    }

    .badge-coming {
        background-color: #fff3cd;
        color: #856404;
    }

    .stats-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 15px;
        margin-top: 20px;
    }

    .stat-box {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 20px;
        border-radius: 10px;
        text-align: center;
    }

    .stat-box .stat-value {
        font-size: 2rem;
        font-weight: bold;
    }

    .stat-box .stat-label {
        font-size: 0.9rem;
        opacity: 0.9;
    }

    .btn-action {
        width: 100%;
        padding: 12px;
        font-weight: 600;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .btn-subscribe {
        background-color: #28a745;
        border-color: #28a745;
        color: white;
    }

    .btn-subscribe:hover {
        background-color: #218838;
        border-color: #218838;
        color: white;
    }

    .btn-view-scores {
        background-color: #007bff;
        border-color: #007bff;
        color: white;
    }

    .btn-view-scores:hover {
        background-color: #0056b3;
        border-color: #0056b3;
        color: white;
    }

    .btn-history {
        background-color: #17a2b8;
        border-color: #17a2b8;
        color: white;
    }

    .btn-history:hover {
        background-color: #117a8b;
        border-color: #117a8b;
        color: white;
    }

    .btn-profile {
        background-color: #6c757d;
        border-color: #6c757d;
        color: white;
    }

    .btn-profile:hover {
        background-color: #5a6268;
        border-color: #5a6268;
        color: white;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-top: 30px;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: bold;
        margin-bottom: 20px;
        color: #333;
        border-bottom: 3px solid #667eea;
        padding-bottom: 10px;
    }

    .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: #6c757d;
    }

    .empty-state-icon {
        font-size: 3rem;
        margin-bottom: 15px;
        opacity: 0.5;
    }

    @@media (max-width: 768px) {
        .player-hero h1 {
            font-size: 1.8rem;
        }

        .action-card .card-header {
            min-height: 100px;
        }

        .card-icon {
            font-size: 2rem;
        }

        .stats-container {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>

<div class="container py-4">
    <div class="player-hero">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1> Bem-vindo @User.Identity?.Name!</h1>
                <p> Essa é a Área do Competidor</p>
            </div>
            <div class="col-md-4">
                <div class="stats-container">
                    <div class="stat-box">
                        <div class="stat-value">10</div>
                        <div class="stat-label">Vitórias em Copas</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-value">10</div>
                        <div class="stat-label">Copas jogadas</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <section class="mb-5">
        <h2 class="section-title">Acesso Rápido</h2>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="card action-card">
                    <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); justify-content: center;">
                        <div style="text-align: center; color: white;">
                            <div class="card-icon">🏆</div>
                            <h5 style="margin: 0;">Inscrição</h5>
                        </div>
                    </div>
                    <div class="card-body">
                        <p class="text-muted" style="font-size: 0.95rem;">
                            Inscreva-se na Próxima Copa Kombfusca
                        </p>
                    </div>
                    <div class="card-footer">
                        <button class="btn btn-action btn-subscribe" data-bs-toggle="modal" data-bs-target="#subscribeModal">
                            Inscrever-se na Copa
                        </button>
                    </div>
                </div>
            </div>

            <!-- View Scores Card -->
            <div class="col-lg-3 col-md-6">
                <div class="card action-card">
                    <div class="card-header" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); justify-content: center;">
                        <div style="text-align: center; color: white;">
                            <div class="card-icon">📊</div>
                            <h5 style="margin: 0;">Pontuações</h5>
                        </div>
                    </div>
                    <div class="card-body">
                        <p class="text-muted" style="font-size: 0.95rem;">
                            Veja a sua pontuação nas últimas Copas Kombfusca e emita certificados (emissão de certificados após 2026).
                        </p>
                    </div>
                    <div class="card-footer">
                        <a href="#" class="btn btn-action btn-view-scores">
                            Ver Pontuações
                        </a>
                    </div>
                </div>
            </div>

            
        </div>
    </section>

    <section class="mb-5">
        <h2 class="section-title">Copas que você participou</h2>
        <div class="info-grid">
            <div class="card action-card">
                <div class="card-body">
                    <h5 class="card-title">Kombfusca Cup 2025</h5>
                    <p class="text-muted">Finalizada - 12 etapas</p>
                    <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #e9ecef;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                            <span>Seu Resultado:</span>
                            <strong style="color: #f5576c; font-size: 1.1rem;">2º 🥈</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between;">
                            <span>Pontos:</span>
                            <strong>587 pts</strong>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card action-card">
                <div class="card-body">
                    <h5 class="card-title">Grand Prix Challenge 2024</h5>
                    <p class="text-muted">Finalizada - 8 etapas</p>
                    <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #e9ecef;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                            <span>Seu Resultado:</span>
                            <strong style="color: #f5d547; font-size: 1.1rem;">1º 🥇</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between;">
                            <span>Pontos:</span>
                            <strong>612 pts</strong>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card action-card">
                <div class="card-body">
                    <h5 class="card-title">Serie Cup 2024</h5>
                    <p class="text-muted">Finalizada - 6 etapas</p>
                    <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #e9ecef;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                            <span>Seu Resultado:</span>
                            <strong style="color: #cd7f32; font-size: 1.1rem;">3º 🥉</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between;">
                            <span>Pontos:</span>
                            <strong>521 pts</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </section>

    <section class="mb-5">
        <div class="row">
            <div class="col-lg-6">
                <div class="card action-card">
                    <div class="card-body">
                        <h5 class="card-title">Ajuda</h5>
                        <ul class="list-unstyled">
                            <li class="mb-2">
                                <strong>Como baixar o certificado?</strong>
                                <p class="text-muted small">Você pode baixar seu certificado de copas a partir de 2026 no seu histórico de pontuações, acessando a copa desejada.</p>
                            </li>
                            <li class="mb-2">
                                <strong>Porque não posso baixar certificados de algumas copas?</strong>
                                <p class="text-muted small">A emissão de certificados só é feita pelo sistema a partir da atualização de 2026. Em copas anteriores, seu certificado impresso continua válido.</p>
                            </li>
                            <li class="mb-2">
                                <strong>Fiz minha inscrição, e agora?</strong>
                                <p class="text-muted small">Após se inscrever com o nome do seu time, você deve pagar a taxa de inscrição para um representante oficial da Copa. Verifique a situação da sua inscrição clicando em "Inscrever-se na Copa"</p>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
