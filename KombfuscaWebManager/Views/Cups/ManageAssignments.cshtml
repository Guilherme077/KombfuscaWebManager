@using KombfuscaWebManager.Models.CupModels.ViewModels
@model CupAssignmentViewModel

@{
    ViewData["Title"] = $"Gerenciar Atribuições - {Model.CupName}";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1>Gerenciar Atribuições de Copa</h1>
            <p class="text-muted">Copa: <strong>@Model.CupName</strong></p>
        </div>
    </div>

    <form method="post">
        <input type="hidden" asp-for="CupId" />

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Selecione os usuários que terão acesso a enviar pontuações para a copa.</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="selectAll" onchange="toggleAllCheckboxes()">
                                        <label class="form-check-label" for="selectAll">
                                            Selecionar Todos
                                        </label>
                                    </div>
                                </th>
                                <th>Usuário</th>
                                <th>Email</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.UserAssignments.Count; i++)
                            {
                                <tr>
                                    <td>
                                        <div class="form-check">
                                            <input class="form-check-input user-checkbox" 
                                                   type="checkbox" 
                                                   asp-for="@Model.UserAssignments[i].IsAssigned"
                                                   id="user_@i">
                                        </div>
                                    </td>
                                    <td>
                                        <input type="hidden" asp-for="@Model.UserAssignments[i].UserId" />
                                        <input type="hidden" asp-for="@Model.UserAssignments[i].UserName" />
                                        <input type="hidden" asp-for="@Model.UserAssignments[i].UserEmail" />
                                        @Model.UserAssignments[i].UserName
                                    </td>
                                    <td>@Model.UserAssignments[i].UserEmail</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.UserAssignments.Count == 0)
                {
                    <div class="alert alert-info">
                        Nenhum usuário disponível para atribuição.
                    </div>
                }
            </div>
            <div class="card-footer">
                <button type="submit" class="btn btn-primary">Salvar Atribuições</button>
                <a href="@Url.Action("Index", "Cups")" class="btn btn-secondary">Cancelar</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function toggleAllCheckboxes() {
            const selectAllCheckbox = document.getElementById('selectAll');
            const userCheckboxes = document.querySelectorAll('.user-checkbox');

            userCheckboxes.forEach(checkbox => {
                checkbox.checked = selectAllCheckbox.checked;
            });
        }

        // Update select all checkbox state based on individual checkboxes
        document.querySelectorAll('.user-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const selectAllCheckbox = document.getElementById('selectAll');
                const userCheckboxes = document.querySelectorAll('.user-checkbox');
                const allChecked = Array.from(userCheckboxes).every(cb => cb.checked);
                const someChecked = Array.from(userCheckboxes).some(cb => cb.checked);

                selectAllCheckbox.checked = allChecked;
                selectAllCheckbox.indeterminate = someChecked && !allChecked;
            });
        });
    </script>
}
